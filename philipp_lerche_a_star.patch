+nigiri::pareto_set<nigiri::routing::journey> a_star_search(
+    nigiri::timetable const& tt,
+    nigiri::routing::a_star_state& algo_state,
+    nigiri::routing::query q) {
+  using namespace nigiri;
+  static auto search_state = routing::search_state{};
+
+  return *(routing::a_star_search(tt, search_state, algo_state, q).journeys_);
+}
